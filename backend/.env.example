# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- Auth ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Blockchain ----
# Local Hardhat node by default. Point this at an RPC provider
# (Infura/Alchemy) for testnet/mainnet.
RPC_URL=http://127.0.0.1:8545

# Private key for the server-side signer used ONLY for verifier-role
# actions (verifyProperty/rejectProperty). This account must be added
# as an approved verifier via setVerifier(). Never reuse a real funds
# wallet here - use a dedicated key.
# The value below is Hardhat's well-known local test account #0 (also the
# auto-approved verifier from the contract constructor) - safe to use
# as-is for local development, never for a real deployment.
SERVER_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ---- Testnet deployment (scripts/deploy.js --network sepolia) ----
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/an5AudMtt5GafY3GA5njZ
DEPLOYER_PRIVATE_KEY=0x4bbbf85ce3377467afe5d46f804f221813b2bb87f24d81f60f1fcdbf7cbf4356
ETHERSCAN_API_KEY=
# ---- IPFS ----
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# ---- Google login (optional) ----
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (type "Web application"), add your frontend origin under Authorized
# JavaScript origins, then paste the client ID here and in the frontend's
# VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
